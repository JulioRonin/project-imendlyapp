// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  client
  provider
  admin
}

enum CertificationStatus {
  pending
  in_review
  approved
  rejected
}

enum ServiceStatus {
  active
  inactive
}

enum RequestStatus {
  initiated
  payment_held
  in_progress
  pending_validation
  completed
  disputed
}

enum EscrowStatus {
  held
  released
  refunded
  disputed
}

enum DisputeStatus {
  open
  resolved
  closed
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  phone            String?
  name             String
  role             Role
  createdAt        DateTime         @default(now())
  clientProfile    ClientProfile?
  providerProfile  ProviderProfile?
}

model ClientProfile {
  userId           String           @id
  user             User             @relation(fields: [userId], references: [id])
  address          String?
  preferredZones   String[]
  ratingAvg        Float            @default(0)
  totalServices    Int              @default(0)
  requests         ServiceRequest[]
}

model ProviderProfile {
  userId              String           @id
  user                User             @relation(fields: [userId], references: [id])
  curp                String?
  rfc                 String?
  ineFrontUrl         String?
  ineBackUrl          String?
  selfieUrl           String?
  criminalRecordUrl   String?
  domicileUrl         String?
  portfolioUrls       String[]
  certificationStatus CertificationStatus @default(pending)
  certificationDate   DateTime?
  badgeVisible        Boolean          @default(false)
  interviewDate       DateTime?
  services            String[]
  zones               String[]
  hourlyRate          Float?
  yearsExperience     Int?
  ratingAvg           Float            @default(0)
  totalServices       Int              @default(0)
  completionRate      Float            @default(0)
  requests            ServiceRequest[]
}

model ServiceCategory {
  id           String    @id @default(uuid())
  name         String
  icon         String?
  pricingModel String
  services     Service[]
}

model Service {
  id                   String           @id @default(uuid())
  categoryId           String
  category             ServiceCategory  @relation(fields: [categoryId], references: [id])
  providerId           String
  title                String
  description          String
  priceMin             Float?
  priceMax             Float?
  pricingUnit          String?
  estimatedDurationMin Int?
  includesMaterials    Boolean          @default(false)
  status               ServiceStatus    @default(active)
  requests             ServiceRequest[]
}

model ServiceRequest {
  id                String           @id @default(uuid())
  clientId          String
  client            ClientProfile    @relation(fields: [clientId], references: [userId])
  providerId        String
  provider          ProviderProfile  @relation(fields: [providerId], references: [userId])
  serviceId         String
  service           Service          @relation(fields: [serviceId], references: [id])
  status            RequestStatus    @default(initiated)
  address           String
  zone              String
  scheduledAt       DateTime
  description       String?
  quotedAmount      Float?
  finalAmount       Float?
  createdAt         DateTime         @default(now())
  escrowTransaction EscrowTransaction?
  disputes          Dispute[]
  messages          Message[]
  reviews           Review[] @relation("RequestReviews")
}

model EscrowTransaction {
  id                 String           @id @default(uuid())
  requestId          String           @unique
  request            ServiceRequest   @relation(fields: [requestId], references: [id])
  amount             Float
  commissionRate     Float
  commissionAmount   Float
  netProviderAmount  Float
  status             EscrowStatus     @default(held)
  paymentMethod      String?
  conektaChargeId    String?
  releaseTrigger     String?
  heldAt             DateTime         @default(now())
  releasedAt         DateTime?
}

model Dispute {
  id              String           @id @default(uuid())
  requestId       String
  request         ServiceRequest   @relation(fields: [requestId], references: [id])
  openedBy        String
  reason          String
  evidenceUrls    String[]
  status          DisputeStatus    @default(open)
  adminResolution String?
  resolvedBy      String?
  openedAt        DateTime         @default(now())
  resolvedAt      DateTime?
}

model Review {
  id         String           @id @default(uuid())
  requestId  String
  request    ServiceRequest   @relation("RequestReviews", fields: [requestId], references: [id])
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime         @default(now())
}

model Message {
  id        String           @id @default(uuid())
  requestId String
  request   ServiceRequest   @relation(fields: [requestId], references: [id])
  senderId  String
  content   String
  type      String           @default("text")
  sentAt    DateTime         @default(now())
  readAt    DateTime?
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      JSON?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
